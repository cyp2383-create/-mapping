# ===== Required =====
# DeepSeek API Key — AI 提取 & 报告生成
# Get at: https://platform.deepseek.com/
DEEPSEEK_KEY=sk-xxx

# Tavily API Key — Web 搜索 & 候选人发现
# Get at: https://tavily.com/
TAVILY_KEY=tvly-xxx

# ===== Required (Vercel deployment) =====
# Turso Database — 历史报告存储
# Get at: https://turso.tech/
TURSO_URL=libsql://xxx.turso.io
TURSO_TOKEN=eyJxxx

# ===== Optional =====
# GitHub Personal Access Token — 提升 API 频率限制 (60→5000次/小时)
# Get at: https://github.com/settings/tokens
GITHUB_TOKEN=
